# Supabase
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_KEY=your-anon-key
SUPABASE_SERVICE_KEY=your-service-role-key

# 카카오 OAuth (Supabase 대시보드 Authentication > Providers > Kakao 에도 동일하게 입력)
KAKAO_REST_API_KEY=your-kakao-rest-api-key
KAKAO_CLIENT_SECRET=your-kakao-client-secret

# 키움 REST API (시세 조회용 — 계좌번호 불필요)
KIWOOM_APP_KEY=your-app-key
KIWOOM_APP_SECRET=your-app-secret

# 한국투자증권 API (해외 시세 조회용 — 계좌번호 불필요)
KIS_APP_KEY=your-app-key
KIS_APP_SECRET=your-app-secret

# 네이버 검색 API (뉴스)
NAVER_CLIENT_ID=your-naver-client-id
NAVER_CLIENT_SECRET=your-naver-client-secret

# 웹 푸시 알림 (VAPID) — uv run vapid --gen 으로 생성
VAPID_PRIVATE_KEY=your-vapid-private-key
VAPID_PUBLIC_KEY=your-vapid-public-key
VAPID_EMAIL=mailto:your@email.com

